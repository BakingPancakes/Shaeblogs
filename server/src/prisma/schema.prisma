//  npx prisma generate

generator client {
  // prisma-client is unstable in v 6, so using an older provider
  provider = "prisma-client-js"
  output   = "../../../shared/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  // no longer supported as of prisma 7
  // url       = env("DATABASE_URL")
  // directUrl = env("DIRECT_URL")
}

enum Page {
  SIPS // cafe reviews
  FLICS // image gallery
  FRIENDS // fun things with friends
  EATS // restaurant reviews
}

model article {
  id String @id @default(cuid())
  page Page
  title String @unique
  thumbnail String? // store a url, not the image itself
  createdAt DateTime @default(now())
  publishedAt DateTime? // for if a draft is saved before publishing
  updatedAt DateTime?
  content String // stored as Markdown
  summary String?
  @@index([publishedAt])
  @@index([page])
}